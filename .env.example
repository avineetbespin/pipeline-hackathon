# Copy to .env for local dev. DO NOT commit .env.
# In production, all of these come from Secret Manager + Cloud Run env injection.

# --- GCP ---
GOOGLE_CLOUD_PROJECT=bgus-genai-poc2
GOOGLE_CLOUD_LOCATION=global         # MUST be 'global' for Gemini 3.x previews
GOOGLE_GENAI_USE_VERTEXAI=True

# --- Fivetran ---
# Get these from https://fivetran.com/account/settings (API Access)
# For local dev only — production reads from Secret Manager.
FIVETRAN_API_KEY=
FIVETRAN_API_SECRET=

# --- MCP server (after Phase 2 deploy) ---
FIVETRAN_MCP_URL=http://localhost:8081

# --- BigQuery ---
BIGQUERY_DATASET=pipelinepilot

# --- Slack (Phase 4) ---
SLACK_WEBHOOK_URL=
